    private static final int C_TEXT = Color.parseColor("#1E293B");
    private static final int C_TEXT_2 = Color.parseColor("#64748B");
    private static final int C_TEXT_HINT = Color.parseColor("#94A3B8");
    private static final int C_DANGER = Color.parseColor("#EF4444");
    private static final int C_SUCCESS = Color.parseColor("#22C55E");
    private static final int C_WARNING = Color.parseColor("#F59E0B");
    private static final int C_DIVIDER = Color.parseColor("#E2E8F0");
