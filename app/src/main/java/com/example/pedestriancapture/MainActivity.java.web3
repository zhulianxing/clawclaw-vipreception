        vibRow.addView(vibSwitch);
        vibCard.addView(vibRow);
        box.addView(vibCard, lp(-1, -2, 0, dp(8), 0, dp(12)));

        // 通知铃声开关
        LinearLayout alarmCard = card();
        alarmCard.setPadding(dp(16), dp(14), dp(16), dp(14));
        LinearLayout alarmRow = hBox();
        alarmRow.setGravity(Gravity.CENTER_VERTICAL);
        alarmRow.addView(tv("🔔 识别时通知铃声", C_TEXT, 14, Typeface.NORMAL));
        View flexAlarm = new View(this);
        flexAlarm.setLayoutParams(new LinearLayout.LayoutParams(0, 1, 1));
        alarmRow.addView(flexAlarm);
        Switch alarmSwitch = new Switch(this);
        alarmSwitch.setChecked(config.isAlarmSoundEnabled());
        alarmSwitch.setOnCheckedChangeListener((b, checked) -> config.setAlarmSoundEnabled(checked));
        alarmRow.addView(alarmSwitch);
        alarmCard.addView(alarmRow);
        box.addView(alarmCard, lp(-1, -2, 0, dp(0), 0, dp(20)));
        box.addView(sectionTitle("💾 数据管理"));

        // 导出数据
        LinearLayout exportCard = card();
        exportCard.setPadding(dp(16), dp(14), dp(16), dp(14));
        LinearLayout exportRow = hBox();
        exportRow.setGravity(Gravity.CENTER_VERTICAL);
        exportRow.addView(tv("📤 导出到店记录", C_TEXT, 14, Typeface.NORMAL));
        View flex4 = new View(this);
        flex4.setLayoutParams(new LinearLayout.LayoutParams(0, 1, 1));
        exportRow.addView(flex4);
        exportRow.addView(tv("→", C_TEXT_HINT, 16, Typeface.NORMAL));
        exportCard.addView(exportRow);
        exportCard.setOnClickListener(v -> exportRecords());
        box.addView(exportCard, lp(-1, -2, 0, dp(8), 0, dp(8)));

        // 清空底库
        LinearLayout clearTargetsCard = card();
        clearTargetsCard.setPadding(dp(16), dp(14), dp(16), dp(14));
        LinearLayout clearTargetsRow = hBox();
        clearTargetsRow.setGravity(Gravity.CENTER_VERTICAL);
        clearTargetsRow.addView(tv("🗑️ 清空VIP客户库", C_DANGER, 14, Typeface.NORMAL));
        View flex5 = new View(this);
        flex5.setLayoutParams(new LinearLayout.LayoutParams(0, 1, 1));
        clearTargetsRow.addView(flex5);
        clearTargetsRow.addView(tv("→", C_TEXT_HINT, 16, Typeface.NORMAL));
        clearTargetsCard.addView(clearTargetsRow);
        clearTargetsCard.setOnClickListener(v -> {
            new AlertDialog.Builder(this)
                    .setTitle("清空底库")
                    .setMessage("确定要清空所有VIP客户吗？此操作不可撤销。")
                    .setPositiveButton("清空", (d, w) -> {
                        store.clearTargets();
                        Toast.makeText(this, "已清空底库", Toast.LENGTH_SHORT).show();
                        showSettings();
                    })
                    .setNegativeButton("取消", null)
                    .show();
        });
        box.addView(clearTargetsCard, lp(-1, -2, 0, dp(0), 0, dp(20)));

        // 关于
        box.addView(sectionTitle("ℹ️ 关于"));

        // 授权状态卡片
        LinearLayout licenseCard = card();
        licenseCard.setPadding(dp(16), dp(16), dp(16), dp(16));

        LinearLayout licenseRow = hBox();
        licenseRow.setGravity(Gravity.CENTER_VERTICAL);
        String licenseIcon = license.isActivated() ? "✅" : (license.isTrialExpired() ? "🔒" : "⏳");
        licenseRow.addView(tv(licenseIcon, C_TEXT, 20, Typeface.NORMAL));
        View licIconGap = new View(this);
        licIconGap.setLayoutParams(new LinearLayout.LayoutParams(dp(10), 0));
        licenseRow.addView(licIconGap);
        LinearLayout licenseInfo = vBox();
        licenseInfo.setLayoutParams(new LinearLayout.LayoutParams(-2, -2));
        licenseInfo.setPadding(dp(10), 0, 0, 0);
        licenseInfo.addView(tv("授权状态", C_TEXT, 14, Typeface.BOLD));
        licenseInfo.addView(spacer(dp(2)));
        licenseInfo.addView(tv(license.getStatusText(), C_TEXT_2, 12, Typeface.NORMAL));
        licenseRow.addView(licenseInfo);
        View licFlex = new View(this);
        licFlex.setLayoutParams(new LinearLayout.LayoutParams(0, 1, 1));
        licenseRow.addView(licFlex);

        if (!license.isActivated()) {
            Button activateBtnInSettings = new Button(this);
            activateBtnInSettings.setText(license.isTrialExpired() ? "激活" : "提前激活");
            activateBtnInSettings.setAllCaps(false);
