        box.addView(licenseCard, lp(-1, -2, 0, dp(8), 0, dp(12)));

        // 版本信息
        LinearLayout aboutCard = card();
        aboutCard.setPadding(dp(16), dp(16), dp(16), dp(16));
        aboutCard.addView(tv("智能迎宾", C_TEXT, 16, Typeface.BOLD));
        aboutCard.addView(spacer(dp(4)));
        aboutCard.addView(tv("版本：" + getAppVersion(), C_TEXT_2, 13, Typeface.NORMAL));
        aboutCard.addView(spacer(dp(4)));
        aboutCard.addView(tv("基于 CameraX 的离线单点值守识别应用\n支持VIP客户底库管理、实时匹配、到店记录与统计分析\n\n所有数据仅保存在本机，请在合法合规场景下使用。",
                C_TEXT_2, 13, Typeface.NORMAL));
        box.addView(aboutCard, lp(-1, -2, 0, dp(8), 0, 0));

        content.addView(scroll, new LinearLayout.LayoutParams(-1, -1));
        updateTopStatus();
