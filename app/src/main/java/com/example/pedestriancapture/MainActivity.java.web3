        View flex2 = new View(this);
        flex2.setLayoutParams(new LinearLayout.LayoutParams(0, 1, 1));
        maxRow.addView(flex2);
        final TextView maxvalue = tv(String.valueOf(config.getMaxRecords()), C_PRIMARY, 15, Typeface.BOLD);
        maxRow.addView(maxvalue);
        maxCard.addView(maxRow);
        SeekBar maxBar = new SeekBar(this);
        maxBar.setMax(970);
        maxBar.setProgress(config.getMaxRecords() - 30);
        maxBar.setOnSeekBarChangeListener(new SeekBar.OnSeekBarChangeListener() {
            @Override public void onProgressChanged(SeekBar s, int p, boolean f) {
                maxvalue.setText(String.valueOf(p + 30));
            }
            @Override public void onStartTrackingTouch(SeekBar s) {}
            @Override public void onStopTrackingTouch(SeekBar s) {
                config.setMaxRecords(s.getProgress() + 30);
            }
        });
        maxCard.addView(maxBar, lp(-1, -2, 0, dp(8), 0, 0));
        box.addView(maxCard, lp(-1, -2, 0, dp(0), 0, dp(20)));

        // 通知设置
