    private void exportRecords() {
        List<CaptureRecord> records = store.loadRecords();
        if (records.isEmpty()) {
            Toast.makeText(this, "暂无记录可导出", Toast.LENGTH_SHORT).show();
            return;
        }
        StringBuilder sb = new StringBuilder();
        sb.append("时间,目标,匹配分,模式,图片路径\n");
        SimpleDateFormat sdf = new SimpleDateFormat("yyyy-MM-dd HH:mm:ss", Locale.CHINA);
        for (CaptureRecord r : records) {
            sb.append(sdf.format(new Date(r.capturedAt))).append(",")
              .append(r.targetName).append(",")
              .append(Math.round(r.score * 100)).append("%,")
              .append(r.mode).append(",")
              .append(r.imagePath).append("\n");
        }
        File exportDir = new File(getExternalFilesDir(null), "exports");
        if (!exportDir.exists()) exportDir.mkdirs();
        File exportFile = new File(exportDir, "records_" + new SimpleDateFormat("yyyyMMdd_HHmmss", Locale.CHINA).format(new Date()) + ".csv");
        try {
            java.io.FileWriter fw = new java.io.FileWriter(exportFile);
            fw.write(sb.toString());
            fw.close();
            Toast.makeText(this, "✅ 已导出到 " + exportFile.getAbsolutePath(), Toast.LENGTH_LONG).show();
        } catch (Exception e) {
            Toast.makeText(this, "导出失败: " + e.getMessage(), Toast.LENGTH_SHORT).show();
        }
    }

    private void pickLocalPhoto() {
        Intent intent = new Intent(Intent.ACTION_OPEN_DOCUMENT);
        intent.addCategory(Intent.CATEGORY_OPENABLE);
        intent.setType("image/*");
        intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION | Intent.FLAG_GRANT_PERSISTABLE_URI_PERMISSION);
        startActivityForResult(intent, REQ_PHOTO);
    }

    /**
     * 显示照片特征提取与算法验证面板
     * 上传照片后立即展示：128维特征详情 + 六维度评分 + 验证结论
     */
    private void showFeatureExtractionPanel(Uri photoUri) {
        Bitmap photo = loadBitmapFromUri(photoUri);
        if (photo == null) {
            Toast.makeText(this, "照片读取失败，请重新选择", Toast.LENGTH_LONG).show();
            return;
        }

        // 提取特征
        FeatureVector fv = FeatureExtractor.extractFromBitmap(photo, null);
        float quality = fv.qualityScore();
        float colorDist = fv.colorDistinctiveness();
        float textureDist = fv.textureDistinctiveness();

        // 自检：与自己比较（理想情况应接近 1.0）
        float selfScore = fv.weightedCosineSimilarity(fv);

        // 各维度自检
        float colorSelf = fv.colorSimilarity(fv);
        float textureSelf = fv.textureSimilarity(fv);
        float edgeSelf = fv.silhouetteSimilarity(fv);
        float bodySelf = fv.bodySimilarity(fv);

        // 检测人脸和人体区域
        android.graphics.Rect personRect = FeatureExtractor.getLastPersonRect();
        android.graphics.Rect faceRect = FeatureExtractor.getLastFaceRect();

        // 构建验证面板
        ScrollView scroll = new ScrollView(this);
        LinearLayout panel = vBox();
        panel.setPadding(dp(16), dp(16), dp(16), dp(24));
        scroll.addView(panel);

        // 标题
        panel.addView(sectionTitle("🔍 特征提取与算法验证"));

        // 1. 照片预览
        LinearLayout photoCard = card();
        photoCard.setPadding(dp(12), dp(12), dp(12), dp(12));
        LinearLayout photoRow = hBox();
        photoRow.setGravity(Gravity.CENTER_VERTICAL);

        // 缩略图
        int thumbW = dp(100), thumbH = dp(140);
        float scale = Math.min((float) thumbW / photo.getWidth(), (float) thumbH / photo.getHeight());
        int w = Math.round(photo.getWidth() * scale);
        int h = Math.round(photo.getHeight() * scale);
        ImageView thumbView = new ImageView(this);
        GradientDrawable thumbBg = new GradientDrawable();
        thumbBg.setCornerRadius(dp(8));
        thumbBg.setColor(C_BG);
        thumbView.setBackground(thumbBg);
        thumbView.setClipToOutline(true);
        thumbView.setImageBitmap(Bitmap.createScaledBitmap(photo, w, h, true));
        photoRow.addView(thumbView, lp(w, h, 0, 0, dp(12), 0));

        LinearLayout photoInfo = vBox();
        photoInfo.addView(tv("原始尺寸: " + photo.getWidth() + "×" + photo.getHeight(), C_TEXT_2, 12, Typeface.NORMAL));
        photoInfo.addView(spacer(dp(4)));
        photoInfo.addView(tv("检测区域: " + (personRect != null ? personRect.width() + "×" + personRect.height() : "默认全图"), C_TEXT_2, 12, Typeface.NORMAL));
        photoInfo.addView(spacer(dp(4)));
        String faceInfo = faceRect != null
            ? "人脸检测: ✅ " + faceRect.width() + "×" + faceRect.height() + "px"
            : "人脸检测: ❌ 未检测到";
        int faceColor = faceRect != null ? C_SUCCESS : C_WARNING;
        TextView faceTv = tv(faceInfo, faceColor, 12, Typeface.NORMAL);
        photoInfo.addView(faceTv);
        photoRow.addView(photoInfo, new LinearLayout.LayoutParams(0, -2, 1));
        photoCard.addView(photoRow);
        panel.addView(photoCard, lp(-1, -2, 0, 0, 0, dp(8)));

        // 2. 特征质量评分
        LinearLayout qualityCard = card();
        qualityCard.setPadding(dp(16), dp(14), dp(16), dp(14));
        qualityCard.addView(tv("📊 特征质量评估", C_TEXT, 15, Typeface.BOLD));
        qualityCard.addView(spacer(dp(8)));

        qualityCard.addView(qualityBar("整体质量", quality, 0.35f, 0.70f));
        qualityCard.addView(spacer(dp(4)));
        qualityCard.addView(qualityBar("颜色区分度", colorDist, 0.20f, 0.50f));
        qualityCard.addView(spacer(dp(4)));
        qualityCard.addView(qualityBar("纹理区分度", textureDist, 0.15f, 0.40f));
        panel.addView(qualityCard, lp(-1, -2, 0, 0, 0, dp(8)));

        // 3. 六维度自检评分
        LinearLayout dimCard = card();
        dimCard.setPadding(dp(16), dp(14), dp(16), dp(14));
        dimCard.addView(tv("📐 六维度自检评分", C_TEXT, 15, Typeface.BOLD));
        dimCard.addView(spacer(dp(8)));

        String[] dimNames = {"颜色直方图", "LBP纹理", "边缘方向", "体态比例", "姿态关键点", "综合融合"};
        float[] dimScores = {colorSelf, textureSelf, edgeSelf, bodySelf, fv.weightedCosineSimilarity(fv), selfScore};
        float[] dimWeights = {0.30f, 0.20f, 0.10f, 0.15f, 0.10f, 1.0f};

        for (int i = 0; i < dimNames.length; i++) {
            LinearLayout dimRow = hBox();
            dimRow.setGravity(Gravity.CENTER_VERTICAL);
            dimRow.addView(tv(dimNames[i], C_TEXT_2, 13, Typeface.NORMAL), new LinearLayout.LayoutParams(0, -2, 1));
            String weightStr = i < 5 ? "权重" + Math.round(dimWeights[i] * 100) + "%" : "";
            dimRow.addView(tv(weightStr, C_TEXT_HINT, 11, Typeface.NORMAL));
            View gap2 = new View(this);
            gap2.setLayoutParams(new LinearLayout.LayoutParams(dp(8), 0));
            dimRow.addView(gap2);
            int scoreColor = dimScores[i] >= 0.85 ? C_SUCCESS : (dimScores[i] >= 0.60 ? C_WARNING : C_DANGER);
            dimRow.addView(tv(Math.round(dimScores[i] * 100) + "%", scoreColor, 14, Typeface.BOLD));
            dimCard.addView(dimRow);
            if (i < dimNames.length - 1) dimCard.addView(spacer(dp(4)));
        }
        panel.addView(dimCard, lp(-1, -2, 0, 0, 0, dp(8)));

        // 4. 128维特征向量摘要
        LinearLayout vecCard = card();
        vecCard.setPadding(dp(16), dp(14), dp(16), dp(14));
        vecCard.addView(tv("🧬 128维特征向量摘要", C_TEXT, 15, Typeface.BOLD));
        vecCard.addView(spacer(dp(8)));

        // 颜色直方图 (48 dims)
        float[] colorHist = fv.getColorHistogram();
        vecCard.addView(featureSummaryRow("颜色直方图 (48维)", colorHist, "HSV三区域"));
        vecCard.addView(spacer(dp(4)));
        // LBP纹理 (16 dims)
        float[] textureHist = fv.getTextureHistogram();
        vecCard.addView(featureSummaryRow("LBP纹理 (16维)", textureHist, "衣着纹理"));
        vecCard.addView(spacer(dp(4)));
        // 边缘方向 (9 dims)
        float[] eoh = fv.getEdgeOrientation();
        vecCard.addView(featureSummaryRow("边缘方向 (9维)", eoh, "Sobel梯度"));
        vecCard.addView(spacer(dp(4)));
        // 人体比例 (8 dims)
        float[] body = fv.getBodyRatios();
        vecCard.addView(featureSummaryRow("人体比例 (8维)", body, "肩宽/腰臀/身高"));
        vecCard.addView(spacer(dp(4)));
        // 姿态关键点 (12 dims)
        float[] pose = fv.getPoseKeypoints();
        vecCard.addView(featureSummaryRow("姿态关键点 (12维)", pose, "鼻/肩/髋/膝"));
        vecCard.addView(spacer(dp(4)));
        // 辅助特征 (4 dims)
        float[] aux = fv.getAuxiliaryFeatures();
        vecCard.addView(featureSummaryRow("辅助特征 (4维)", aux, "体型/性别/年龄"));
        panel.addView(vecCard, lp(-1, -2, 0, 0, 0, dp(8)));

        // 5. 可用性结论
        LinearLayout conclusionCard = card();
        conclusionCard.setPadding(dp(16), dp(14), dp(16), dp(14));
        boolean usable = fv.isUsable();
        boolean qualityOk = quality >= 0.50f;
        boolean colorOk = colorDist >= 0.20f;

        int conclusionColor = (usable && qualityOk) ? C_SUCCESS : (usable ? C_WARNING : C_DANGER);
        String conclusionIcon = (usable && qualityOk) ? "✅" : (usable ? "⚠️" : "❌");
        String conclusionText;
        if (usable && qualityOk && colorOk) {
            conclusionText = "照片特征提取成功，质量良好\n该照片适合作为VIP客户底库照片\n保存后将在值守时用于特征匹配";
        } else if (usable && qualityOk && !colorOk) {
            conclusionText = "照片特征可用，但颜色区分度偏低\n建议使用色彩更鲜明的照片\n（如衣着颜色清晰可见的正面照）";
        } else if (usable) {
            conclusionText = "照片特征勉强可用，但质量偏低\n建议使用更清晰、光线充足的照片\n（全身照、正面、无遮挡）";
        } else {
            conclusionText = "照片特征质量不足，无法有效匹配\n请重新选择：\n• 清晰的正面全身照\n• 光线充足、无逆光\n• 衣着颜色清晰可见";
        }
        conclusionCard.addView(tv(conclusionIcon + " 验证结论", conclusionColor, 15, Typeface.BOLD));
        conclusionCard.addView(spacer(dp(6)));
        conclusionCard.addView(tv(conclusionText, C_TEXT_2, 13, Typeface.NORMAL));
        panel.addView(conclusionCard, lp(-1, -2, 0, 0, 0, dp(8)));

        // 6. 操作按钮
        LinearLayout btnRow = hBox();
        btnRow.setGravity(Gravity.CENTER_VERTICAL);

        final android.app.Dialog dialog = new android.app.Dialog(this);

        if (usable) {
            Button useBtn = btn("使用此照片", C_PRIMARY, Color.WHITE);
            useBtn.setOnClickListener(v -> {
                dialog.dismiss();
                // 保持 selectedPhotoUri 不变，允许用户填写信息后保存
                if (selectedPhotoLabel != null) {
                    selectedPhotoLabel.setText("✅ 照片已验证，质量" + Math.round(quality * 100) + "%，可保存到底库");
                    selectedPhotoLabel.setTextColor(C_SUCCESS);
                }
            });
            btnRow.addView(useBtn, new LinearLayout.LayoutParams(0, -2, 1));
        }

        Button reselectBtn = btn("重新选择", C_BG, C_TEXT);
        reselectBtn.setOnClickListener(v -> {
            dialog.dismiss();
            selectedPhotoUri = null;
            pickLocalPhoto();
        });
        btnRow.addView(reselectBtn, new LinearLayout.LayoutParams(0, -2, 1));

        if (usable) {
            View gap3 = new View(this);
            gap3.setLayoutParams(new LinearLayout.LayoutParams(dp(8), 0));
            btnRow.addView(gap3);
        }

        panel.addView(btnRow, lp(-1, -2, 0, dp(8), 0, 0));

        photo.recycle();

        dialog.setContentView(scroll);
        dialog.getWindow().setLayout(LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.MATCH_PARENT);
        dialog.setTitle(null);
        dialog.show();
    }

    /**
     * 质量评分进度条
     */
    private LinearLayout qualityBar(String label, float value, float warnThreshold, float okThreshold) {
        LinearLayout row = vBox();
        LinearLayout labelRow = hBox();
        labelRow.setGravity(Gravity.CENTER_VERTICAL);
        labelRow.addView(tv(label, C_TEXT_2, 13, Typeface.NORMAL), new LinearLayout.LayoutParams(0, -2, 1));
        int valColor = value >= okThreshold ? C_SUCCESS : (value >= warnThreshold ? C_WARNING : C_DANGER);
        labelRow.addView(tv(Math.round(value * 100) + "%", valColor, 13, Typeface.BOLD));
        row.addView(labelRow);
        row.addView(spacer(dp(4)));

        // 进度条
        android.widget.ProgressBar pb = new android.widget.ProgressBar(this, null, android.R.attr.progressBarStyleHorizontal);
        pb.setMax(100);
        pb.setProgress(Math.round(value * 100));
        pb.getProgressDrawable().setColorFilter(valColor, android.graphics.PorterDuff.Mode.SRC_IN);
        row.addView(pb, lp(-1, dp(6), 0, 0, 0, 0));
        return row;
    }

    /**
     * 特征向量摘要行
     */
    private LinearLayout featureSummaryRow(String title, float[] data, String desc) {
        LinearLayout row = vBox();
        LinearLayout header = hBox();
        header.setGravity(Gravity.CENTER_VERTICAL);
        header.addView(tv(title, C_TEXT, 13, Typeface.NORMAL), new LinearLayout.LayoutParams(0, -2, 1));
        header.addView(tv(desc, C_TEXT_HINT, 11, Typeface.NORMAL));
        row.addView(header);
        row.addView(spacer(dp(2)));

        // 统计信息
        float min = Float.MAX_VALUE, max = Float.MIN_VALUE, sum = 0, energy = 0;
        for (float v : data) {
            min = Math.min(min, v);
            max = Math.max(max, v);
            sum += v;
            energy += v * v;
        }
        float mean = sum / data.length;
        float std = 0;
        for (float v : data) std += (v - mean) * (v - mean);
        std = (float) Math.sqrt(std / data.length);

        // 简易直方图可视化 (取前16个值)
        LinearLayout histRow = hBox();
        histRow.setMinimumHeight(dp(40));
        int displayCount = Math.min(data.length, 16);
        float maxAbs = 0;
        for (int i = 0; i < displayCount; i++) maxAbs = Math.max(maxAbs, Math.abs(data[i]));
        if (maxAbs == 0) maxAbs = 1;
        for (int i = 0; i < displayCount; i++) {
            View bar = new View(this);
            float ratio = Math.abs(data[i]) / maxAbs;
            int barH = Math.max(dp(3), (int) (dp(30) * ratio));
            int barColor = data[i] >= 0 ? Color.parseColor("#D97706") : Color.parseColor("#EF4444");
            GradientDrawable barBg = new GradientDrawable();
            barBg.setColor(barColor);
            barBg.setCornerRadius(dp(1));
            bar.setBackground(barBg);
            histRow.addView(bar, lp(dp(6), barH, 0, dp(1), 0, 0));
        }
        row.addView(histRow);
        row.addView(spacer(dp(2)));

        row.addView(tv(String.format("min=%.3f max=%.3f mean=%.3f std=%.3f", min, max, mean, std),
                       C_TEXT_HINT, 10, Typeface.NORMAL));
        return row;
    }

    private Bitmap loadBitmapFromUri(Uri uri) {
        if (uri == null) return null;
        try {
            java.io.InputStream inputStream = getContentResolver().openInputStream(uri);
            if (inputStream == null) return null;
            Bitmap bitmap = BitmapFactory.decodeStream(inputStream);
            inputStream.close();
            return bitmap;
        } catch (Exception e) {
            return null;
        }
    }

    private void registerStoredTargetsWithPhotos() {
        List<PersonTarget> targets = store.loadTargets();
        for (PersonTarget target : targets) {
            if (!TextUtils.isEmpty(target.photoUri) && !target.photoUri.startsWith("http")) {
                Bitmap photo = loadBitmapFromUri(Uri.parse(target.photoUri));
                if (photo != null) {
                    matcher.registerTargetWithPhoto(target, photo);
                    photo.recycle();
                } else {
                    matcher.registerTarget(target);
                }
            } else {
                matcher.registerTarget(target);
            }
        }
    }

    private void verifyTargetPhoto(PersonTarget target) {
        if (target == null || TextUtils.isEmpty(target.photoUri)) {
            Toast.makeText(this, "该目标没有本地照片，无法验证", Toast.LENGTH_SHORT).show();
            return;
        }
        if (target.photoUri.startsWith("http")) {
            Toast.makeText(this, "网络照片已禁用，请重新上传本地照片", Toast.LENGTH_LONG).show();
            return;
        }

        Bitmap photo = loadBitmapFromUri(Uri.parse(target.photoUri));
        if (photo == null) {
            Toast.makeText(this, "照片读取失败，请重新上传", Toast.LENGTH_LONG).show();
            return;
        }

        matcher.registerTargetWithPhoto(target, photo);
        OfflineMatcher.VerificationResult result = matcher.verifyTargetWithPhoto(target, photo);
        photo.recycle();

        String detail = "目标：" + target.name
                + "\n自检分：" + Math.round(result.score * 100) + "%"
                + "\n第二名：" + Math.round(result.secondBestScore * 100) + "%"
                + "\n分差：" + Math.round(result.margin * 100) + "%"
                + "\n质量：" + Math.round(result.quality * 100) + "%"
                + "\n结论：" + (result.passed ? "照片特征可用" : "照片特征不可靠，需要更清晰/更完整的行人照片");

        new AlertDialog.Builder(this)
                .setTitle(result.passed ? "验证通过" : "验证未通过")
                .setMessage(detail)
                .setPositiveButton("知道了", null)
                .show();
    }

    @Override
    protected void onActivityResult(int requestCode, int resultCode, Intent data) {
        super.onActivityResult(requestCode, resultCode, data);
        if (requestCode == REQ_PHOTO && resultCode == RESULT_OK && data != null && data.getData() != null) {
            selectedPhotoUri = data.getData();
            try {
                getContentResolver().takePersistableUriPermission(
                        selectedPhotoUri,
                        Intent.FLAG_GRANT_READ_URI_PERMISSION
                );
            } catch (Exception ignored) {
            }
            // 上传后立即显示特征提取与算法验证面板
            showFeatureExtractionPanel(selectedPhotoUri);
        }
    }

