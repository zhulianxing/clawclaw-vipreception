            activateBtnInSettings.setTextSize(TypedValue.COMPLEX_UNIT_SP, 12);
            activateBtnInSettings.setPadding(dp(16), dp(8), dp(16), dp(8));
            GradientDrawable actBtnBg = new GradientDrawable();
            actBtnBg.setCornerRadius(dp(8));
            actBtnBg.setColor(C_PRIMARY);
            activateBtnInSettings.setBackground(actBtnBg);
            activateBtnInSettings.setOnClickListener(v -> showActivationDialog());
            licenseRow.addView(activateBtnInSettings);
        }

        licenseCard.addView(licenseRow);

        if (license.isActivated()) {
            licenseCard.addView(spacer(dp(8)));
            String codeDisplay = license.getActivationCode();
