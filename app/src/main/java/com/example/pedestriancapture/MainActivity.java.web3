    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        store = new LocalStore(this);
        config = new AppConfig(this);
        license = new LicenseManager(this);
        web3License = new Web3LicenseManager(this);
        threshold = config.getThreshold();
        duplicateGuard.setIntervalSeconds(config.getDedupInterval());
        buildShell();
        switchTab(0);
        checkLicense();
        registerStoredTargetsWithPhotos();
    }

    // ==================== 主框架 ====================

    private void buildShell() {
        root = new LinearLayout(this);
        root.setOrientation(LinearLayout.VERTICAL);
        root.setBackgroundColor(C_BG);

        // 顶部标题栏
        LinearLayout topBar = new LinearLayout(this);
        topBar.setOrientation(LinearLayout.VERTICAL);
        topBar.setBackgroundColor(C_PRIMARY);
        topBar.setPadding(0, dp(48), 0, dp(14));

        topTitle = new TextView(this);
        topTitle.setTextColor(Color.WHITE);
        topTitle.setTextSize(TypedValue.COMPLEX_UNIT_SP, 20);
        topTitle.setTypeface(Typeface.DEFAULT_BOLD);
        topTitle.setGravity(Gravity.CENTER);
        topBar.addView(topTitle);

        topStatus = new TextView(this);
        topStatus.setTextColor(Color.parseColor("#BFDBFE"));
        topStatus.setTextSize(TypedValue.COMPLEX_UNIT_SP, 12);
        topStatus.setGravity(Gravity.CENTER);
        topStatus.setPadding(0, dp(3), 0, 0);
        topBar.addView(topStatus);

        root.addView(topBar);

        // 内容区域
        content = new LinearLayout(this);
        content.setOrientation(LinearLayout.VERTICAL);
        root.addView(content, new LinearLayout.LayoutParams(-1, 0, 1));

        // 底部导航
        bottomNav = new LinearLayout(this);
        bottomNav.setBackgroundColor(C_NAV_BG);
        bottomNav.setOrientation(LinearLayout.VERTICAL);

        View divider = new View(this);
        divider.setBackgroundColor(C_DIVIDER);
        bottomNav.addView(divider, new LinearLayout.LayoutParams(-1, dp(1)));

        LinearLayout navRow = new LinearLayout(this);
        navRow.setPadding(0, dp(8), 0, dp(24));
        navRow.setGravity(Gravity.CENTER);
        navRow.addView(navTab("📷", "监控", 0));
        navRow.addView(navTab("👥", "底库", 1));
        navRow.addView(navTab("📸", "记录", 2));
        navRow.addView(navTab("📊", "统计", 3));
        navRow.addView(navTab("⚙️", "设置", 4));
        bottomNav.addView(navRow);

        root.addView(bottomNav);
        setContentView(root);
    }

    private LinearLayout navTab(String icon, String label, final int tab) {
        LinearLayout tabLayout = new LinearLayout(this);
        tabLayout.setOrientation(LinearLayout.VERTICAL);
        tabLayout.setGravity(Gravity.CENTER);
        tabLayout.setPadding(dp(8), dp(4), dp(8), dp(4));
        tabLayout.setOnClickListener(v -> switchTab(tab));

        TextView iconView = new TextView(this);
        iconView.setText(icon);
        iconView.setTextSize(TypedValue.COMPLEX_UNIT_SP, 20);
        iconView.setGravity(Gravity.CENTER);
        iconView.setTag("nav_icon_" + tab);
        tabLayout.addView(iconView);

        TextView labelView = new TextView(this);
        labelView.setText(label);
        labelView.setTextSize(TypedValue.COMPLEX_UNIT_SP, 11);
        labelView.setGravity(Gravity.CENTER);
        labelView.setTag("nav_label_" + tab);
        tabLayout.addView(labelView);

        tabLayout.setLayoutParams(new LinearLayout.LayoutParams(0, -2, 1));
        return tabLayout;
    }

    private void switchTab(int tab) {
        currentTab = tab;
        // 更新导航栏高亮
        for (int i = 0; i < 5; i++) {
            TextView label = (TextView) bottomNav.findViewWithTag("nav_label_" + i);
            if (label != null) {
                label.setTextColor(i == tab ? C_PRIMARY : C_TEXT_HINT);
            }
        }
        content.removeAllViews();
        // 停止相机当离开监控页
        if (tab != 0) {
            stopStatusTimer();
            stopCamera();
        }
        switch (tab) {
            case 0: topTitle.setText("实时监控"); showMonitor(); break;
            case 1: topTitle.setText("VIP客户库"); showTargets(); break;
            case 2: topTitle.setText("到店记录"); showRecords(); break;
            case 3: topTitle.setText("统计分析"); showStats(); break;
            case 4: topTitle.setText("设置"); showSettings(); break;
        }
        updateTopStatus();
    }

    private void updateTopStatus() {
        int targetCount = store.loadTargets().size();
        int recordCount = store.loadRecords().size();
        String status;
        switch (currentTab) {
            case 0: status = "关注 " + targetCount + " 人 · 识别 " + recordCount + " 次"; break;
            case 1: status = "共 " + targetCount + " 位VIP客户"; break;
            case 2: status = "共 " + recordCount + " 条到店记录"; break;
            case 3: status = "数据统计与分析"; break;
            case 4: status = "应用设置"; break;
            default: status = ""; break;
        }
        topStatus.setText(status);
    }

    // ==================== 页面1: 实时监控 ====================

    private void showMonitor() {
        ScrollView scroll = new ScrollView(this);
        scroll.setBackgroundColor(C_BG);
        LinearLayout box = vBox();
        box.setPadding(dp(16), dp(16), dp(16), dp(16));

        // ===== 值守控制面板 =====
        LinearLayout controlCard = card();
        controlCard.setPadding(dp(20), dp(20), dp(20), dp(20));

        // 状态指示灯 + 文字
        LinearLayout statusRow = hBox();
        statusRow.setGravity(Gravity.CENTER_VERTICAL);

        TextView statusDot = new TextView(this);
        statusDot.setText("⚪");
        statusDot.setTextSize(TypedValue.COMPLEX_UNIT_SP, 28);
        statusDot.setTag("status_dot");
        statusRow.addView(statusDot);

        LinearLayout statusInfo = vBox();
        statusInfo.setPadding(dp(12), 0, 0, 0);
        monitorStatusTv = tv("未启动值守", C_TEXT, 16, Typeface.BOLD);
        statusInfo.addView(monitorStatusTv);
        monitorTimerTv = tv("点击下方按钮开始监控", C_TEXT_2, 12, Typeface.NORMAL);
        monitorTimerTv.setPadding(0, dp(2), 0, 0);
        statusInfo.addView(monitorTimerTv);
        statusRow.addView(statusInfo);

        View flexStatus = new View(this);
        flexStatus.setLayoutParams(new LinearLayout.LayoutParams(0, 1, 1));
        statusRow.addView(flexStatus);

        controlCard.addView(statusRow);
        controlCard.addView(spacer(dp(16)));

        // 开始值守按钮（大号醒目）
        startMonitorBtn = new Button(this);
        startMonitorBtn.setText("▶  开始值守");
        startMonitorBtn.setAllCaps(false);
        startMonitorBtn.setTextColor(Color.WHITE);
        startMonitorBtn.setTextSize(TypedValue.COMPLEX_UNIT_SP, 16);
        startMonitorBtn.setTypeface(Typeface.DEFAULT_BOLD);
        startMonitorBtn.setPadding(dp(20), dp(16), dp(20), dp(16));
        GradientDrawable startBg = new GradientDrawable();
        startBg.setCornerRadius(dp(12));
        startBg.setColor(C_PRIMARY);
        startMonitorBtn.setBackground(startBg);
        startMonitorBtn.setOnClickListener(v -> startMonitoring(preview));
        controlCard.addView(startMonitorBtn, lp(-1, -2, 0, 0, 0, 0));

        controlCard.addView(spacer(dp(10)));

        // 停止按钮
        stopMonitorBtn = new Button(this);
        stopMonitorBtn.setText("⏹  停止值守");
        stopMonitorBtn.setAllCaps(false);
        stopMonitorBtn.setTextColor(C_TEXT_2);
        stopMonitorBtn.setTextSize(TypedValue.COMPLEX_UNIT_SP, 15);
        stopMonitorBtn.setPadding(dp(20), dp(14), dp(20), dp(14));
        GradientDrawable stopBg = new GradientDrawable();
        stopBg.setCornerRadius(dp(12));
        stopBg.setColor(Color.parseColor("#F1F5F9"));
        stopMonitorBtn.setBackground(stopBg);
        stopMonitorBtn.setOnClickListener(v -> stopMonitoring());
        stopMonitorBtn.setEnabled(false);
        stopMonitorBtn.setAlpha(0.5f);
        controlCard.addView(stopMonitorBtn, lp(-1, -2, 0, 0, 0, 0));

        box.addView(controlCard, lp(-1, -2, 0, 0, 0, dp(12)));

        // ===== 阈值卡片 =====
        LinearLayout thresholdCard = card();
        thresholdCard.setPadding(dp(16), dp(16), dp(16), dp(16));

        LinearLayout thresholdHeader = hBox();
        thresholdHeader.setGravity(Gravity.CENTER_VERTICAL);
        TextView thresholdTitle = tv("匹配阈值", C_TEXT, 14, Typeface.NORMAL);
        thresholdHeader.addView(thresholdTitle);
        int tc = store.loadTargets().size();
        String adaptHint = tc <= 1 ? " · 精确匹配" : tc <= 3 ? " · 标准匹配" : tc <= 10 ? " · 宽松匹配" : " · 大底库";
        TextView adaptTv = tv(adaptHint, C_TEXT_2, 11, Typeface.NORMAL);
        thresholdHeader.addView(adaptTv);
        View flex = new View(this);
        flex.setLayoutParams(new LinearLayout.LayoutParams(0, 1, 1));
        thresholdHeader.addView(flex);
        final TextView thresholdValue = tv(Math.round(threshold * 100) + "%", C_PRIMARY, 18, Typeface.BOLD);
        thresholdHeader.addView(thresholdValue);
        thresholdCard.addView(thresholdHeader);

        SeekBar thresholdBar = new SeekBar(this);
        thresholdBar.setMax(40);
        thresholdBar.setProgress(Math.round((threshold - 0.55f) * 100));
        thresholdBar.setOnSeekBarChangeListener(new SeekBar.OnSeekBarChangeListener() {
            @Override public void onProgressChanged(SeekBar s, int p, boolean f) {
                threshold = 0.55f + p / 100f;
                thresholdValue.setText(Math.round(threshold * 100) + "%");
            }
            @Override public void onStartTrackingTouch(SeekBar s) {}
            @Override public void onStopTrackingTouch(SeekBar s) {
                config.setThreshold(threshold);
            }
        });
        thresholdCard.addView(thresholdBar, lp(-1, -2, 0, dp(8), 0, 0));
        box.addView(thresholdCard, lp(-1, -2, 0, 0, 0, dp(12)));

