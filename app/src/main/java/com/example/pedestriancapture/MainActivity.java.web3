        LinearLayout previewCard = card();
        FrameLayout previewContainer = new FrameLayout(this);
        preview = new PreviewView(this);
        preview.setScaleType(PreviewView.ScaleType.FILL_CENTER);
        previewContainer.addView(preview, new FrameLayout.LayoutParams(-1, dp(320)));

        // 检测叠加层
        overlayView = new DetectionOverlayView(this);
        previewContainer.addView(overlayView, new FrameLayout.LayoutParams(-1, dp(320)));

        previewCard.addView(previewContainer, lp(-1, -2, 0, 0, 0, 0));
        box.addView(previewCard, lp(-1, -2, 0, 0, 0, dp(12)));

        // 实时检测状态条
        liveDetectTv = tv("📋 等待开始值守...", C_TEXT_2, 12, Typeface.NORMAL);
        liveDetectTv.setPadding(dp(12), dp(8), dp(12), dp(8));
        liveDetectTv.setBackgroundColor(Color.parseColor("#F8FAFC"));
        box.addView(liveDetectTv, lp(-1, -2, 0, 0, 0, dp(8)));

        // ===== 提示信息 =====
        TextView hint = tv("💡 点击「开始值守」启动摄像头监控\n   检测到VIP客户时自动识别并提醒\n   去重间隔：" + config.getDedupInterval() + "秒",
                C_TEXT_2, 13, Typeface.NORMAL);
        hint.setLineSpacing(dp(4), 1f);
        hint.setPadding(dp(8), dp(8), dp(8), dp(8));
        box.addView(hint);

        scroll.addView(box);
        content.addView(scroll, new LinearLayout.LayoutParams(-1, -1));

        // 恢复值守状态显示
        if (isMonitoring) {
            updateMonitorUIRunning();
            // 重新绑定相机到新的 PreviewView
            if (cameraController != null) {
                cameraController.bindToLifecycle(this);
                preview.setController(cameraController);
            }
        }
    }

    private PreviewView preview;
    private DetectionOverlayView overlayView;
    private TextView liveDetectTv; // 实时检测状态

    private void startMonitoring(PreviewView previewView) {
        if (licenseBlocked) {
            showActivationDialog();
            return;
        }
        if (!hasCameraPermission()) {
            requestPermissions(new String[]{Manifest.permission.CAMERA}, REQ_CAMERA);
            return;
        }
        isMonitoring = true;
        monitorStartTime = System.currentTimeMillis();
        startCamera(previewView);
        updateMonitorUIRunning();
        startStatusTimer();
    }

    private void stopMonitoring() {
        isMonitoring = false;
        stopCamera();
        stopStatusTimer();
        updateMonitorUIStopped();
        if (overlayView != null) overlayView.clear();
        if (liveDetectTv != null) {
            liveDetectTv.setText("📋 值守已停止");
            liveDetectTv.setTextColor(C_TEXT_2);
        }
    }

    private void updateMonitorUIRunning() {
        TextView statusDot = (TextView) content.findViewWithTag("status_dot");
        if (statusDot != null) statusDot.setText("🔴");
        if (monitorStatusTv != null) monitorStatusTv.setText("VIP值守中...");
        if (monitorStatusTv != null) monitorStatusTv.setTextColor(C_DANGER);
        if (startMonitorBtn != null) { startMonitorBtn.setEnabled(false); startMonitorBtn.setAlpha(0.5f); }
        if (stopMonitorBtn != null) { stopMonitorBtn.setEnabled(true); stopMonitorBtn.setAlpha(1.0f); }
    }

    private void updateMonitorUIStopped() {
        TextView statusDot = (TextView) content.findViewWithTag("status_dot");
        if (statusDot != null) statusDot.setText("⚪");
        if (monitorStatusTv != null) { monitorStatusTv.setText("已停止值守"); monitorStatusTv.setTextColor(C_TEXT); }
        if (monitorTimerTv != null) monitorTimerTv.setText("点击「开始值守」重新启动");
        if (startMonitorBtn != null) { startMonitorBtn.setEnabled(true); startMonitorBtn.setAlpha(1.0f); }
        if (stopMonitorBtn != null) { stopMonitorBtn.setEnabled(false); stopMonitorBtn.setAlpha(0.5f); }
        updateTopStatus();
    }

    private void startStatusTimer() {
        stopStatusTimer();
        statusTimer[0] = new java.util.Timer();
        statusTimer[0].scheduleAtFixedRate(new java.util.TimerTask() {
            @Override
            public void run() {
                runOnUiThread(() -> {
                    if (isMonitoring && monitorTimerTv != null) {
                        long elapsed = System.currentTimeMillis() - monitorStartTime;
                        int hours = (int) (elapsed / 3600000);
                        int mins = (int) ((elapsed % 3600000) / 60000);
                        int secs = (int) ((elapsed % 60000) / 1000);
                        String timeStr = String.format(Locale.CHINA, "%02d:%02d:%02d", hours, mins, secs);
                        int targetCount = store.loadTargets().size();
                        int recordCount = store.loadRecords().size();
                        monitorTimerTv.setText("⏱ 值守时长 " + timeStr + " · 关注 " + targetCount + " 人 · 已识别 " + recordCount + " 次");
                    }
                });
            }
        }, 0, 1000);
    }

    private void stopStatusTimer() {
        if (statusTimer[0] != null) {
            statusTimer[0].cancel();
            statusTimer[0] = null;
        }
    }

    private void startCamera(PreviewView previewView) {
        if (!hasCameraPermission()) {
            requestPermissions(new String[]{Manifest.permission.CAMERA}, REQ_CAMERA);
            return;
        }
        registerStoredTargetsWithPhotos();
        currentPreviewView = previewView;
        if (cameraController == null) {
            cameraController = new LifecycleCameraController(this);
            cameraController.setCameraSelector(androidx.camera.core.CameraSelector.DEFAULT_BACK_CAMERA);
            cameraController.setEnabledUseCases(
                    androidx.camera.view.CameraController.IMAGE_CAPTURE
                    | androidx.camera.view.CameraController.IMAGE_ANALYSIS);
        }
        // 绑定到生命周期并设置到 PreviewView
        cameraController.bindToLifecycle(this);
        previewView.setController(cameraController);
        cameraBound = true;

        // ImageAnalysis analyzer - 使用真实特征提取
        cameraController.setImageAnalysisBackpressureStrategy(ImageAnalysis.STRATEGY_KEEP_ONLY_LATEST);
        cameraController.setImageAnalysisAnalyzer(getMainExecutor(), image -> {
            long now = System.currentTimeMillis();
            if (now - lastAnalysisAt > 450) {
                lastAnalysisAt = now;
                // 从帧提取特征向量
                FeatureVector frameFeature = FeatureExtractor.extractFromFrame(image, null);
                MatchResult result = matcher.match(store.loadTargets(), frameFeature, threshold);

                // 更新叠加层
                if (overlayView != null) {
                    DetectionOverlayView.DetectionResult dr = new DetectionOverlayView.DetectionResult();
                    dr.personRect = result.personRect;
                    dr.faceRect = result.faceRect;
                    dr.matched = result.matched;
                    dr.targetName = result.target != null ? result.target.name : null;
                    dr.totalScore = result.score;
                    dr.dimensionScores = result.dimensionScores;
                    dr.dimensionLabels = new String[]{"颜色", "纹理", "边缘", "体态", "姿态", "综合"};
                    overlayView.setPreviewSize(image.getWidth(), image.getHeight());
                    overlayView.updateDetection(dr);
                }

                // 更新实时状态条
                if (liveDetectTv != null) {
                    if (result.matched) {
                        liveDetectTv.setText(String.format("🎯 匹配: %s | 总分: %d%% | 模式: %s",
                            result.target.name, Math.round(result.score * 100), result.mode));
                        liveDetectTv.setTextColor(Color.parseColor("#16A34A"));
                    } else if (result.personRect != null) {
                        liveDetectTv.setText("👁 检测到运动目标，匹配中...");
                        liveDetectTv.setTextColor(Color.parseColor("#D97706"));
                    } else {
                        liveDetectTv.setText("🔍 监控中... 未检测到运动目标");
                        liveDetectTv.setTextColor(C_TEXT_2);
                    }
                }

                if (result.matched && duplicateGuard.canCapture(result.target.id)) {
                    captureHit(result);
                }
            }
            image.close();
        });

        topStatus.setText("🔴 监控中 · 阈值 " + Math.round(threshold * 100) + "%");
    }

    private void stopCamera() {
        if (cameraController != null) {
            cameraController.unbind();
        }
        cameraBound = false;
        if (currentTab == 0) {
            topStatus.setText("已停止值守");
        }
    }

    @Override
    protected void onDestroy() {
        super.onDestroy();
        stopStatusTimer();
        stopCamera();
    }

    private void captureHit(MatchResult result) {
        CaptureRecord record = new CaptureRecord(result.target.id, result.target.name, result.score, result.mode);
        File dir = new File(getFilesDir(), "captures");
        if (!dir.exists()) dir.mkdirs();
        File image = new File(dir, record.id + ".jpg");
        record.imagePath = image.getAbsolutePath();

        if (cameraController == null) {
            store.saveRecord(record);
            alert(record, result);
            return;
        }
        ImageCapture.OutputFileOptions options = new ImageCapture.OutputFileOptions.Builder(image).build();
        cameraController.takePicture(options, getMainExecutor(), new ImageCapture.OnImageSavedCallback() {
            @Override public void onImageSaved(@NonNull ImageCapture.OutputFileResults r) {
                store.saveRecord(record);
                alert(record, result);
            }
            @Override public void onError(@NonNull ImageCaptureException e) {
                record.imagePath = "";
                store.saveRecord(record);
                alert(record, result);
            }
        });
    }

    private void alert(CaptureRecord record, MatchResult matchResult) {
        if (config.isVibrationEnabled()) {
            Vibrator vibrator = getSystemService(Vibrator.class);
            if (vibrator != null) {
                vibrator.vibrate(VibrationEffect.createOneShot(400, VibrationEffect.DEFAULT_AMPLITUDE));
            }
        }
        // 通知铃声
        if (config.isAlarmSoundEnabled()) {
            playAlarmSound();
        }

        LinearLayout dialogContent = vBox();
        dialogContent.setPadding(dp(16), dp(8), dp(16), dp(8));

        if (!TextUtils.isEmpty(record.imagePath)) {
            File imgFile = new File(record.imagePath);
            if (imgFile.exists()) {
                Bitmap bitmap = BitmapFactory.decodeFile(record.imagePath);
                if (bitmap != null) {
                    ImageView imageView = new ImageView(this);
                    int maxW = dp(280), maxH = dp(350);
                    float scale = Math.min((float) maxW / bitmap.getWidth(), (float) maxH / bitmap.getHeight());
                    int w = Math.round(bitmap.getWidth() * scale);
                    int h = Math.round(bitmap.getHeight() * scale);
                    imageView.setImageBitmap(Bitmap.createScaledBitmap(bitmap, w, h, true));
                    dialogContent.addView(imageView, lp(w, h, 0, 0, 0, dp(12)));
                }
            }
        }

        TextView info = tv("🎯 目标：" + record.targetName
                + "\n📊 匹配分：" + Math.round(record.score * 100) + "%"
                + "\n🔍 模式：" + record.mode
                + "\n⏰ " + new SimpleDateFormat("HH:mm:ss", Locale.CHINA).format(new Date(record.capturedAt)),
                C_TEXT, 14, Typeface.NORMAL);
        info.setLineSpacing(dp(4), 1f);
        dialogContent.addView(info);

        // 六维度评分详情
        if (matchResult != null && matchResult.dimensionScores != null) {
            String[] labels = {"颜色", "纹理", "边缘", "体态", "姿态", "综合"};
            StringBuilder sb = new StringBuilder();
            for (int i = 0; i < matchResult.dimensionScores.length && i < labels.length; i++) {
                int pct = Math.round(matchResult.dimensionScores[i] * 100);
                String bar = pct >= 70 ? "🟩" : pct >= 50 ? "🟨" : "🟥";
                sb.append(labels[i]).append(" ").append(bar).append(" ").append(pct).append("%");
                if (i < matchResult.dimensionScores.length - 1) sb.append("  ");
            }
            TextView dimInfo = tv(sb.toString(), C_TEXT_2, 11, Typeface.NORMAL);
            dimInfo.setLineSpacing(dp(2), 1f);
            dimInfo.setPadding(0, dp(4), 0, 0);
            dialogContent.addView(dimInfo);
        }

        // 倒计时显示
        final TextView countdownTv = tv("", C_PRIMARY, 13, Typeface.NORMAL);
        countdownTv.setGravity(Gravity.CENTER);
        countdownTv.setPadding(0, dp(10), 0, 0);
        dialogContent.addView(countdownTv);

        final AlertDialog[] dialogHolder = new AlertDialog[1];
        final int[] countdown = {5};
        countdownTv.setText("⏳ " + countdown[0] + " 秒后自动继续值守...");

        dialogHolder[0] = new AlertDialog.Builder(this)
                .setTitle("🚨 发现VIP客户")
                .setView(dialogContent)
                .setPositiveButton("查看记录", (d, w) -> switchTab(2))
                .setNegativeButton("立即继续", null)
                .setCancelable(false)
                .show();

        final java.util.Timer timer = new java.util.Timer();
        timer.scheduleAtFixedRate(new java.util.TimerTask() {
            @Override
            public void run() {
                runOnUiThread(() -> {
                    countdown[0]--;
                    if (countdown[0] <= 0) {
                        timer.cancel();
                        if (dialogHolder[0] != null && dialogHolder[0].isShowing()) {
                            dialogHolder[0].dismiss();
                        }
                        updateTopStatus();
                    } else {
                        countdownTv.setText("⏳ " + countdown[0] + " 秒后自动继续值守...");
                    }
                });
            }
        }, 1000, 1000);
    }

    // ==================== 页面2: VIP客户库 ====================

    private void showTargets() {
        showTargets(false);
    }

    private void showTargets(final boolean scrollToList) {
        final ScrollView scroll = new ScrollView(this);
        scroll.setBackgroundColor(C_BG);
        final LinearLayout box = vBox();
        box.setPadding(dp(16), dp(16), dp(16), dp(24));
        scroll.addView(box);

        // 底库列表（放在表单之前，让新条目立即可见）
        List<PersonTarget> targets = store.loadTargets();
        box.addView(sectionTitle("📋 当前底库（" + targets.size() + "）"));

        if (targets.isEmpty()) {
            LinearLayout emptyCard = card();
            emptyCard.setPadding(dp(20), dp(40), dp(20), dp(40));
            TextView empty = tv("暂无VIP客户\n\n请在下方录入VIP客户信息", C_TEXT_HINT, 14, Typeface.NORMAL);
            empty.setGravity(Gravity.CENTER);
            emptyCard.addView(empty);
            box.addView(emptyCard, lp(-1, -2, 0, dp(8), 0, 0));
        } else {
            for (PersonTarget target : targets) {
                LinearLayout itemCard = card();
                itemCard.setPadding(dp(16), dp(14), dp(16), dp(14));

                LinearLayout header = hBox();
                header.setGravity(Gravity.CENTER_VERTICAL);
                TextView nameTv = tv(target.name, C_TEXT, 16, Typeface.BOLD);
                header.addView(nameTv);

                if (!"未设置".equals(target.gender) && !TextUtils.isEmpty(target.gender)) {
                    View gap = new View(this);
                    gap.setLayoutParams(new LinearLayout.LayoutParams(dp(8), 0));
                    header.addView(gap);
                    header.addView(tag(target.gender, Color.parseColor("#E0E7FF"), Color.parseColor("#4338CA")));
                }
                // 照片标识
                if (!TextUtils.isEmpty(target.photoUri)) {
                    header.addView(tag("📷照片", Color.parseColor("#FEF3C7"), Color.parseColor("#92400E")));
                }
                View flex = new View(this);
                flex.setLayoutParams(new LinearLayout.LayoutParams(0, 1, 1));
                header.addView(flex);

                // 删除按钮
                TextView deleteBtn = tv("🗑️", C_TEXT_HINT, 18, Typeface.NORMAL);
                deleteBtn.setPadding(dp(8), 0, dp(8), 0);
                deleteBtn.setOnClickListener(v -> {
                    new AlertDialog.Builder(this)
                            .setTitle("删除确认")
                            .setMessage("确定要删除「" + target.name + "」吗？")
                            .setPositiveButton("删除", (d, w) -> {
                                store.deleteTarget(target.id);
                                matcher.unregisterTarget(target.id); // 移除特征缓存
                                Toast.makeText(this, "已删除", Toast.LENGTH_SHORT).show();
                                showTargets();
                            })
                            .setNegativeButton("取消", null)
                            .show();
                });
                header.addView(deleteBtn);
                itemCard.addView(header);
                itemCard.addView(spacer(dp(6)));

                StringBuilder details = new StringBuilder();
                if (!TextUtils.isEmpty(target.clothing)) details.append("👕 ").append(target.clothing).append("\n");
                if (!TextUtils.isEmpty(target.accessories)) details.append("🎒 ").append(target.accessories).append("\n");
                if (!TextUtils.isEmpty(target.bodyShape)) details.append("🚶 ").append(target.bodyShape);
                if (details.length() > 0) {
                    TextView detailTv = tv(details.toString().trim(), C_TEXT_2, 13, Typeface.NORMAL);
                    detailTv.setLineSpacing(dp(3), 1f);
                    itemCard.addView(detailTv);
                }

                if (!TextUtils.isEmpty(target.photoUri)) {
                    itemCard.addView(spacer(dp(8)));
                    Button verifyBtn = btn("反向验证照片特征", Color.parseColor("#E0F2FE"), Color.parseColor("#0369A1"));
                    verifyBtn.setOnClickListener(v -> verifyTargetPhoto(target));
                    itemCard.addView(verifyBtn);
                }

                box.addView(itemCard, lp(-1, -2, 0, dp(6), 0, 0));
            }
        }

        // 录入卡片（放在列表之后）
        box.addView(spacer(dp(20)));
        box.addView(sectionTitle("➕ 添加VIP客户"));

        LinearLayout formCard = card();
        formCard.setPadding(dp(16), dp(16), dp(16), dp(16));

        final EditText nameField = input("姓名 / 编号");
        formCard.addView(nameField);
        formCard.addView(spacer(dp(8)));
        final EditText genderField = input("性别");
        formCard.addView(genderField);
        formCard.addView(spacer(dp(8)));
        final EditText clothingField = input("衣着特征（如黑色上衣、蓝色长裤）");
        formCard.addView(clothingField);
        formCard.addView(spacer(dp(8)));
        final EditText accessoriesField = input("配饰（如帽子、口罩、背包）");
        formCard.addView(accessoriesField);
        formCard.addView(spacer(dp(8)));
        final EditText bodyShapeField = input("体态（如高瘦、中等、步态明显）");
        formCard.addView(bodyShapeField);
        formCard.addView(spacer(dp(8)));

        selectedPhotoUri = null;
        selectedPhotoLabel = tv("未选择照片。请上传本地照片，APP 会从照片提取VIP客户特征。", C_TEXT_2, 13, Typeface.NORMAL);
        selectedPhotoLabel.setLineSpacing(dp(3), 1f);
        formCard.addView(selectedPhotoLabel);
        formCard.addView(spacer(dp(8)));

        Button pickPhotoBtn = btn("上传本地照片", Color.parseColor("#E0F2FE"), Color.parseColor("#0369A1"));
        pickPhotoBtn.setOnClickListener(v -> pickLocalPhoto());
        formCard.addView(pickPhotoBtn);
        formCard.addView(spacer(dp(12)));

        Button saveBtn = btn("保存到底库", C_PRIMARY, Color.WHITE);
        saveBtn.setOnClickListener(v -> {
            if (selectedPhotoUri == null) {
                Toast.makeText(this, "请先上传本地照片，当前版本不再支持网络图片 URL", Toast.LENGTH_LONG).show();
                return;
            }
            PersonTarget target = new PersonTarget(textOr(nameField, "未命名目标"));
            target.gender = textOr(genderField, "未设置");
            target.clothing = clothingField.getText().toString();
            target.accessories = accessoriesField.getText().toString();
            target.bodyShape = bodyShapeField.getText().toString();
            target.photoUri = selectedPhotoUri.toString();

            Bitmap photo = loadBitmapFromUri(selectedPhotoUri);
            if (photo == null) {
                Toast.makeText(this, "照片读取失败，请重新选择一张清晰的本地照片", Toast.LENGTH_LONG).show();
                return;
            }

            store.saveTarget(target);
            matcher.registerTargetWithPhoto(target, photo);
            OfflineMatcher.VerificationResult verification = matcher.verifyTargetWithPhoto(target, photo);
            photo.recycle();

            String message = verification.passed
                    ? "✅ 已加入VIP库，照片特征验证通过：" + Math.round(verification.score * 100) + "%"
                    : "⚠️ 已加入VIP库，但照片特征验证偏低：" + Math.round(verification.score * 100) + "%";
            Toast.makeText(this, message, Toast.LENGTH_LONG).show();
            selectedPhotoUri = null;
            showTargets(true);
        });
        formCard.addView(saveBtn);
        box.addView(formCard, lp(-1, -2, 0, dp(8), 0, dp(20)));

        content.addView(scroll, new LinearLayout.LayoutParams(-1, -1));
        updateTopStatus();

        // 保存后滚动到顶部，让用户看到新添加的条目
        if (scrollToList) {
            scroll.post(() -> scroll.fullScroll(ScrollView.FOCUS_UP));
        }
    }

    // ==================== 页面3: 到店记录 ====================

    private void showRecords() {
        ScrollView scroll = new ScrollView(this);
        scroll.setBackgroundColor(C_BG);
        LinearLayout box = vBox();
        box.setPadding(dp(16), dp(16), dp(16), dp(24));
        scroll.addView(box);

        List<CaptureRecord> records = store.loadRecords();

        // 操作栏
        LinearLayout actionBar = hBox();
        actionBar.setGravity(Gravity.CENTER_VERTICAL);
        actionBar.addView(tv("📋 到店记录（" + records.size() + "）", C_TEXT, 15, Typeface.BOLD));
        View flex = new View(this);
        flex.setLayoutParams(new LinearLayout.LayoutParams(0, 1, 1));
        actionBar.addView(flex);

        if (!records.isEmpty()) {
            Button clearBtn = btn("清空全部", Color.parseColor("#FEE2E2"), C_DANGER);
            clearBtn.setTextSize(TypedValue.COMPLEX_UNIT_SP, 12);
            clearBtn.setPadding(dp(12), dp(6), dp(12), dp(6));
            clearBtn.setOnClickListener(v -> {
                new AlertDialog.Builder(this)
                        .setTitle("清空确认")
                        .setMessage("确定要清空所有到店记录吗？此操作不可撤销。")
                        .setPositiveButton("清空", (d, w) -> {
                            store.clearRecords();
                            // 删除图片文件
                            File dir = new File(getFilesDir(), "captures");
                            if (dir.exists()) {
                                File[] files = dir.listFiles();
                                if (files != null) for (File f : files) f.delete();
                            }
                            Toast.makeText(this, "已清空", Toast.LENGTH_SHORT).show();
                            showRecords();
                        })
                        .setNegativeButton("取消", null)
                        .show();
            });
            actionBar.addView(clearBtn);
        }
        box.addView(actionBar, lp(-1, -2, 0, 0, 0, dp(12)));

        if (records.isEmpty()) {
            LinearLayout emptyCard = card();
            emptyCard.setPadding(dp(20), dp(48), dp(20), dp(48));
            TextView empty = tv("📸 暂无到店记录\n\n启动监控后，检测到VIP客户将自动识别", C_TEXT_HINT, 14, Typeface.NORMAL);
            empty.setGravity(Gravity.CENTER);
            emptyCard.addView(empty);
            box.addView(emptyCard, lp(-1, -2, 0, dp(8), 0, 0));
        } else {
            for (CaptureRecord record : records) {
                box.addView(recordCard(record), lp(-1, -2, 0, dp(6), 0, 0));
            }
        }

        content.addView(scroll, new LinearLayout.LayoutParams(-1, -1));
        updateTopStatus();
    }

    private LinearLayout recordCard(CaptureRecord record) {
        LinearLayout card = card();
        card.setPadding(dp(12), dp(12), dp(12), dp(12));

        LinearLayout row = hBox();

        // 图片缩略图
        if (!TextUtils.isEmpty(record.imagePath)) {
            File imgFile = new File(record.imagePath);
            if (imgFile.exists()) {
                Bitmap bitmap = BitmapFactory.decodeFile(record.imagePath);
                if (bitmap != null) {
                    ImageView imageView = new ImageView(this);
                    int targetW = dp(100), targetH = dp(130);
                    float scale = Math.min((float) targetW / bitmap.getWidth(), (float) targetH / bitmap.getHeight());
                    int w = Math.round(bitmap.getWidth() * scale);
                    int h = Math.round(bitmap.getHeight() * scale);
                    GradientDrawable imgBg = new GradientDrawable();
                    imgBg.setCornerRadius(dp(8));
                    imgBg.setColor(C_BG);
                    imageView.setBackground(imgBg);
                    imageView.setClipToOutline(true);
                    imageView.setImageBitmap(Bitmap.createScaledBitmap(bitmap, w, h, true));
                    row.addView(imageView, lp(w, h, 0, 0, dp(10), 0));
                }
            }
        }

        // 信息区
        LinearLayout info = vBox();
        info.setPadding(dp(4), 0, dp(4), 0);

        TextView nameTv = tv(record.targetName, C_TEXT, 16, Typeface.BOLD);
        info.addView(nameTv);
        info.addView(spacer(dp(4)));

        String time = new SimpleDateFormat("yyyy-MM-dd HH:mm:ss", Locale.CHINA).format(new Date(record.capturedAt));
        TextView timeTv = tv("🕒 " + time, C_TEXT_2, 12, Typeface.NORMAL);
        info.addView(timeTv);
        info.addView(spacer(dp(6)));

        // 标签行
        LinearLayout tagRow = hBox();
        tagRow.setGravity(Gravity.CENTER_VERTICAL);
        int scoreColor = record.score >= 0.85 ? C_SUCCESS : (record.score >= 0.72 ? C_WARNING : C_DANGER);
        tagRow.addView(tag(Math.round(record.score * 100) + "%", lighten(scoreColor), scoreColor));
        View gap = new View(this);
        gap.setLayoutParams(new LinearLayout.LayoutParams(dp(6), 0));
        tagRow.addView(gap);
        tagRow.addView(tag(record.mode, Color.parseColor("#E0E7FF"), Color.parseColor("#4338CA")));
        info.addView(tagRow);

        View flex = new View(this);
        flex.setLayoutParams(new LinearLayout.LayoutParams(0, 1, 1));
        info.addView(flex);

        row.addView(info, new LinearLayout.LayoutParams(0, -2, 1));

        card.addView(row);
        card.setOnClickListener(v -> showFullImage(record));

        // 长按删除
        card.setOnLongClickListener(v -> {
            new AlertDialog.Builder(this)
                    .setTitle("删除记录")
                    .setMessage("确定删除这条到店记录吗？")
                    .setPositiveButton("删除", (d, w) -> {
                        store.deleteRecord(record.id);
                        if (!TextUtils.isEmpty(record.imagePath)) {
                            new File(record.imagePath).delete();
                        }
                        Toast.makeText(this, "已删除", Toast.LENGTH_SHORT).show();
                        showRecords();
                    })
                    .setNegativeButton("取消", null)
                    .show();
            return true;
        });

        return card;
    }

    private void showFullImage(CaptureRecord record) {
        if (TextUtils.isEmpty(record.imagePath) || !new File(record.imagePath).exists()) {
            Toast.makeText(this, "此记录无图片", Toast.LENGTH_SHORT).show();
            return;
        }

        LinearLayout dialogContent = vBox();
        dialogContent.setGravity(Gravity.CENTER);
        dialogContent.setPadding(dp(8), dp(8), dp(8), dp(8));

        Bitmap bitmap = BitmapFactory.decodeFile(record.imagePath);
        if (bitmap != null) {
            ImageView imageView = new ImageView(this);
            int maxW = dp(320), maxH = dp(480);
            float scale = Math.min((float) maxW / bitmap.getWidth(), (float) maxH / bitmap.getHeight());
            int w = Math.round(bitmap.getWidth() * scale);
            int h = Math.round(bitmap.getHeight() * scale);
            imageView.setImageBitmap(Bitmap.createScaledBitmap(bitmap, w, h, true));
            dialogContent.addView(imageView);
        }

        TextView info = tv(record.targetName + " · " + Math.round(record.score * 100) + "% · "
                + new SimpleDateFormat("MM-dd HH:mm", Locale.CHINA).format(new Date(record.capturedAt)),
                C_TEXT_2, 13, Typeface.NORMAL);
        info.setGravity(Gravity.CENTER);
        info.setPadding(0, dp(8), 0, 0);
        dialogContent.addView(info);

        new AlertDialog.Builder(this)
                .setView(dialogContent)
                .setPositiveButton("关闭", null)
                .show();
    }

    // ==================== 页面4: 统计分析 ====================

    private void showStats() {
        ScrollView scroll = new ScrollView(this);
        scroll.setBackgroundColor(C_BG);
        LinearLayout box = vBox();
        box.setPadding(dp(16), dp(16), dp(16), dp(24));
        scroll.addView(box);

        List<CaptureRecord> records = store.loadRecords();
        List<PersonTarget> targets = store.loadTargets();

        // 今日数据卡片
        Calendar today = Calendar.getInstance();
        today.set(Calendar.HOUR_OF_DAY, 0);
        today.set(Calendar.MINUTE, 0);
        today.set(Calendar.SECOND, 0);
        today.set(Calendar.MILLISECOND, 0);
        long todayStart = today.getTimeInMillis();

        int todayCount = 0;
        for (CaptureRecord r : records) {
            if (r.capturedAt >= todayStart) todayCount++;
        }

        // 数据概览
        box.addView(sectionTitle("📊 数据概览"));
        LinearLayout statsRow = hBox();
        statsRow.addView(statCard("今日识别", String.valueOf(todayCount), C_PRIMARY));
        statsRow.addView(spacer(dp(10)));
        statsRow.addView(statCard("总识别", String.valueOf(records.size()), C_SUCCESS));
        statsRow.addView(spacer(dp(10)));
        statsRow.addView(statCard("VIP客户", String.valueOf(targets.size()), C_WARNING));
        box.addView(statsRow, lp(-1, -2, 0, dp(8), 0, dp(20)));

        // 目标分布
        box.addView(sectionTitle("👥 目标识别分布"));
        if (records.isEmpty()) {
            box.addView(emptyCard("暂无数据"), lp(-1, -2, 0, dp(8), 0, dp(20)));
        } else {
            Map<String, Integer> targetCount = new HashMap<>();
            for (CaptureRecord r : records) {
                String name = r.targetName;
                targetCount.put(name, targetCount.getOrDefault(name, 0) + 1);
            }
            List<Map.Entry<String, Integer>> sorted = new ArrayList<>(targetCount.entrySet());
            sorted.sort((a, b) -> b.getValue() - a.getValue());

            int maxCount = sorted.get(0).getValue();
            for (Map.Entry<String, Integer> entry : sorted) {
                LinearLayout barRow = hBox();
                barRow.setGravity(Gravity.CENTER_VERTICAL);
                barCard(barRow, dp(16), dp(10), dp(16), dp(10));

                TextView nameTv = tv(entry.getKey(), C_TEXT, 13, Typeface.NORMAL);
                nameTv.setMaxWidth(dp(100));
                barRow.addView(nameTv);

                // 进度条
                View barBg = new View(this);
                barBg.setBackgroundColor(C_BG);
                GradientDrawable barBgDrawable = new GradientDrawable();
                barBgDrawable.setCornerRadius(dp(4));
                barBgDrawable.setColor(Color.parseColor("#E2E8F0"));
                barBg.setBackground(barBgDrawable);
                LinearLayout.LayoutParams barBgParams = new LinearLayout.LayoutParams(0, dp(20), 1);
                barBgParams.leftMargin = dp(10);
                barRow.addView(barBg, barBgParams);

                // 填充
                float ratio = maxCount > 0 ? (float) entry.getValue() / maxCount : 0;
                View barFill = new View(this);
                GradientDrawable fillDrawable = new GradientDrawable();
                fillDrawable.setCornerRadius(dp(4));
                fillDrawable.setColor(C_PRIMARY);
                barFill.setBackground(fillDrawable);
                FrameLayout barContainer = new FrameLayout(this);
                barContainer.addView(barFill, new FrameLayout.LayoutParams(
                        Math.max(dp(4), (int) (dp(200) * ratio)), dp(20)));

                // 替换 barBg 为 container
                barRow.removeView(barBg);
                barContainer.setLayoutParams(new LinearLayout.LayoutParams(0, dp(20), 1));
                ((LinearLayout.LayoutParams) barContainer.getLayoutParams()).leftMargin = dp(10);
                barRow.addView(barContainer);

                TextView countTv = tv(String.valueOf(entry.getValue()), C_TEXT_2, 13, Typeface.BOLD);
                LinearLayout.LayoutParams countParams = new LinearLayout.LayoutParams(-2, -2);
                countParams.leftMargin = dp(8);
                barRow.addView(countTv, countParams);

                box.addView(barRow, lp(-1, -2, 0, dp(4), 0, 0));
            }
            box.addView(spacer(dp(20)));
        }

        // 最近活动
        box.addView(sectionTitle("🕐 最近活动"));
        if (records.isEmpty()) {
            box.addView(emptyCard("暂无到店记录"), lp(-1, -2, 0, dp(8), 0, 0));
        } else {
            int showCount = Math.min(10, records.size());
            for (int i = 0; i < showCount; i++) {
                CaptureRecord r = records.get(i);
                LinearLayout row = hBox();
                row.setGravity(Gravity.CENTER_VERTICAL);
                barCard(row, dp(14), dp(10), dp(14), dp(10));

                TextView dot = tv("●", r.score >= 0.85 ? C_SUCCESS : (r.score >= 0.72 ? C_WARNING : C_DANGER), 12, Typeface.NORMAL);
                row.addView(dot);

                TextView desc = tv(r.targetName + " · " + Math.round(r.score * 100) + "%",
                        C_TEXT, 13, Typeface.NORMAL);
                LinearLayout.LayoutParams descParams = new LinearLayout.LayoutParams(0, -2, 1);
                descParams.leftMargin = dp(8);
                row.addView(desc, descParams);

                TextView time = tv(new SimpleDateFormat("MM-dd HH:mm", Locale.CHINA).format(new Date(r.capturedAt)),
                        C_TEXT_HINT, 12, Typeface.NORMAL);
                row.addView(time);

                box.addView(row, lp(-1, -2, 0, dp(4), 0, 0));
            }
        }

        content.addView(scroll, new LinearLayout.LayoutParams(-1, -1));
        updateTopStatus();
    }

    // ==================== 页面5: 设置 ====================

    private void showSettings() {
        ScrollView scroll = new ScrollView(this);
        scroll.setBackgroundColor(C_BG);
        LinearLayout box = vBox();
        box.setPadding(dp(16), dp(16), dp(16), dp(24));
        scroll.addView(box);

        // 监控设置
        box.addView(sectionTitle("🎯 监控设置"));

        // 去重间隔
        LinearLayout dedupCard = card();
        dedupCard.setPadding(dp(16), dp(14), dp(16), dp(14));
        LinearLayout dedupRow = hBox();
        dedupRow.setGravity(Gravity.CENTER_VERTICAL);
        dedupRow.addView(tv("去重间隔", C_TEXT, 14, Typeface.NORMAL));
        View flex1 = new View(this);
        flex1.setLayoutParams(new LinearLayout.LayoutParams(0, 1, 1));
        dedupRow.addView(flex1);
        final TextView dedupValue = tv(config.getDedupInterval() + " 秒", C_PRIMARY, 15, Typeface.BOLD);
        dedupRow.addView(dedupValue);
        dedupCard.addView(dedupRow);
        SeekBar dedupBar = new SeekBar(this);
        dedupBar.setMax(120);
        dedupBar.setProgress(config.getDedupInterval() - 5);
        dedupBar.setOnSeekBarChangeListener(new SeekBar.OnSeekBarChangeListener() {
            @Override public void onProgressChanged(SeekBar s, int p, boolean f) {
                int val = p + 5;
                dedupValue.setText(val + " 秒");
            }
            @Override public void onStartTrackingTouch(SeekBar s) {}
            @Override public void onStopTrackingTouch(SeekBar s) {
                int val = s.getProgress() + 5;
                config.setDedupInterval(val);
                duplicateGuard.setIntervalSeconds(val);
            }
        });
        dedupCard.addView(dedupBar, lp(-1, -2, 0, dp(8), 0, 0));
        box.addView(dedupCard, lp(-1, -2, 0, dp(8), 0, dp(12)));

        // 最大记录数
        LinearLayout maxCard = card();
        maxCard.setPadding(dp(16), dp(14), dp(16), dp(14));
        LinearLayout maxRow = hBox();
        maxRow.setGravity(Gravity.CENTER_VERTICAL);
