        TextView labelTv = tv(label, Color.parseColor("#E0E7FF"), 12, Typeface.NORMAL);
        labelTv.setGravity(Gravity.CENTER);
        card.addView(labelTv);

        card.setLayoutParams(new LinearLayout.LayoutParams(0, -2, 1));
        return card;
    }

    private LinearLayout emptyCard(String text) {
        LinearLayout c = card();
        c.setPadding(dp(20), dp(32), dp(20), dp(32));
        TextView t = tv(text, C_TEXT_HINT, 14, Typeface.NORMAL);
        t.setGravity(Gravity.CENTER);
        c.addView(t);
        return c;
    }

    private int dp(int v) {
        return (int) TypedValue.applyDimension(TypedValue.COMPLEX_UNIT_DIP, v, getResources().getDisplayMetrics());
    }

    private String getAppVersion() {
        try {
            android.content.pm.PackageInfo pi = getPackageManager().getPackageInfo(getPackageName(), 0);
            return pi.versionName != null ? pi.versionName : "unknown";
        } catch (Exception e) {
            return "unknown";
        }
    }

    private int lighten(int color) {
        return Color.rgb(
                Math.min(Color.red(color) + 60, 255),
                Math.min(Color.green(color) + 60, 255),
                Math.min(Color.blue(color) + 60, 255)
        );
    }

    private String textOr(EditText et, String fallback) {
        String v = et.getText().toString().trim();
        return v.isEmpty() ? fallback : v;
    }

    private boolean hasCameraPermission() {
        return checkSelfPermission(Manifest.permission.CAMERA) == PackageManager.PERMISSION_GRANTED;
    }

    // ==================== 权限与回调 ====================

    @Override
    public void onRequestPermissionsResult(int requestCode, @NonNull String[] permissions, @NonNull int[] grantResults) {
        super.onRequestPermissionsResult(requestCode, permissions, grantResults);
        if (requestCode == REQ_CAMERA && (grantResults.length == 0 || grantResults[0] != PackageManager.PERMISSION_GRANTED)) {
            new AlertDialog.Builder(this)
                    .setTitle("需要相机权限")
                    .setMessage("开启相机权限后才能进行单点值守识别。")
                    .setPositiveButton("去设置", (d, w) -> {
                        Intent intent = new Intent(Settings.ACTION_APPLICATION_DETAILS_SETTINGS);
                        intent.setData(Uri.parse("package:" + getPackageName()));
                        startActivity(intent);
                    })
                    .setNegativeButton("取消", null)
                    .show();
        }
    }

    // ==================== 授权管理 ====================

    private void checkLicense() {
        // 优先检查 Web3 链上激活
        if (web3License.isWalletConnected()) {
            web3License.checkChainActivation().thenAccept(result -> {
                runOnUiThread(() -> {
                    if (result.activated) {
                        licenseBlocked = false;
                        Toast.makeText(this, "✅ NFT凭证已激活 #" + result.tokenId, Toast.LENGTH_SHORT).show();
                    } else if (web3License.isTrialExpired()) {
                        licenseBlocked = true;
                        showWeb3ActivationDialog();
                    } else {
                        licenseBlocked = false;
                        int remaining = web3License.getRemainingTrialDays();
                        if (remaining <= 3) {
                            topStatus.setText("⏳ 试用剩余 " + remaining + " 天 · " + topStatus.getText());
                        }
                    }
                });
            });
            return;
        }

        // 降级到旧版激活码验证
        if (license.isActivated()) {
            licenseBlocked = false;
            return;
        }
        if (license.isTrialExpired()) {
            licenseBlocked = true;
            if (!license.isTrialExpiredShown()) {
                license.setTrialExpiredShown(true);
                showActivationDialog();
            } else {
                showActivationDialog();
            }
        } else {
            licenseBlocked = false;
            int remaining = license.getRemainingTrialDays();
            if (remaining <= 3) {
                topStatus.setText("⏳ 试用剩余 " + remaining + " 天 · " + topStatus.getText());
            }
        }
    }

